# SECURITY: this file contains NYT session tokens with full account access.
# .env is gitignored, but the skill directory is git-tracked — never `git add .env`.
#
# Copy to .env and paste the five cookies from a logged-in browser session at
# https://www.nytimes.com. To capture them:
#   1) Sign in.
#   2) DevTools -> Application -> Cookies -> https://www.nytimes.com
#   3) Copy each value below.
#   Or:
#   1) DevTools -> Network -> reload -> click any samizdat-graphql.nytimes.com
#      request -> Request Headers -> "Cookie:" -> copy value -> pipe to
#      scripts/set_cookie.py (which extracts the five named cookies for you).
#
# When the skill prints SESSION_EXPIRED, re-paste.

NYT_A=replace-with-nyt-a-cookie-value
NYT_S=replace-with-NYT-S-cookie-value
NYT_JKIDD=replace-with-nyt-jkidd-cookie-value
NYT_PURR=replace-with-nyt-purr-cookie-value
NYT_B_SID=replace-with-nyt-b-sid-cookie-value

# Optional: override the embedded "project-vi" GraphQL client token. The
# default is baked into the skill (a static public client identifier observed
# in the NYT web bundle). Set only if NYT rotates it and the skill starts
# 403'ing all GraphQL calls.
# NYT_TOKEN=

# Optional tuning
# NYT_CACHE_DIR=/absolute/path/to/cache   # default: <skill_dir>/cache
# NYT_REQUEST_SPACING_MS=350              # delay between origin fetches
# NYT_MAX_FETCHES=200                     # per-invocation safety cap
# NYT_USER_AGENT=                         # override the default UA
