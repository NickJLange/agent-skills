{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nyt saved output",
  "type": "object",
  "required": ["schema_version", "fetched_at", "items"],
  "properties": {
    "schema_version": {"const": 1},
    "fetched_at": {"type": "string"},
    "note": {"type": "string"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "saved"],
        "properties": {
          "url": {"type": "string"},
          "saved": {"type": "boolean"}
        }
      }
    }
  }
}
