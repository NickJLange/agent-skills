# SECURITY: this file contains FT session tokens with full account access.
# .env is gitignored, but the skill directory is git-tracked, so:
#   - never `git add .env` or `git add -A` inside this directory
#   - rotate cookies by re-running scripts/set_cookie.py if you suspect leak
#   - if you prefer, point FT_CACHE_DIR and your env loader at a path outside
#     the repo (e.g. ~/.config/ft-reader/.env) and skip the local .env entirely
#
# Copy to .env (in this directory) and paste your FT session.
#
# RECOMMENDED — paste your entire browser Cookie header as FT_COOKIE.
# This is what every endpoint expects, including MyFT (which requires a
# coupled set of cookies beyond the four named ones below).
#
# How to capture:
#   1) Sign in to https://app.ft.com in your browser.
#   2) Open DevTools -> Network tab.
#   3) Reload or click anything that hits app-api.ft.com.
#   4) Click any request, scroll to Request Headers, find "Cookie:".
#   5) Right-click -> Copy value -> paste the entire value below (single line).
#
# Cookies expire periodically. Re-paste when ft-reader reports SESSION_EXPIRED.

FT_COOKIE=paste-the-entire-Cookie-header-value-from-your-browser-here

# Legacy fallback: only the 4 named cookies. Works for `ft headlines`, `ft article`,
# and `ft audio`, but `ft myft` will likely return SESSION_EXPIRED until you also
# set FT_COOKIE. Useful for headless scripts where you can extract these by name.
# FT_SESSION_S=
# FT_CLIENT_SESSION_ID=
# FT_APP_USER=
# FT_CSRF=

# Optional overrides
# FT_CACHE_DIR=/absolute/path/to/cache   # default: <skill_dir>/cache
# FT_REQUEST_SPACING_MS=350              # delay between article/audio fetches
# FT_MAX_FETCHES=200                     # per-invocation safety cap
# FT_USER_AGENT=                         # override the default UA
