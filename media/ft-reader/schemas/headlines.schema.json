{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ft headlines output",
  "type": "object",
  "required": ["schema_version", "fetched_at", "sections"],
  "properties": {
    "schema_version": {"const": 1},
    "fetched_at": {"type": "string"},
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "headlines"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "headlines": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "uuid": {"type": "string"},
                "title": {"type": ["string", "null"]},
                "standfirst": {"type": ["string", "null"]},
                "url": {"type": ["string", "null"]},
                "published": {"type": ["string", "null"]},
                "audio_available": {"type": "boolean"},
                "error": {"type": "string"}
              },
              "required": ["uuid"]
            }
          }
        }
      }
    }
  }
}
